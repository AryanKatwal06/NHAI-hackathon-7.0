/ios/main.jsbundle

# ─── ENVIRONMENT AND SECRETS ──────────────────────────────────────────────────
# NEVER commit real environment files
.env
.env.development
.env.production
.env.staging
.env.local

# Android signing keys — NEVER commit these
android/app/release.keystore
android/app/*.keystore
*.jks

# AWS credentials — NEVER commit these
.aws/
aws/credentials
aws/samconfig.toml

# ─── AI MODEL FILES ───────────────────────────────────────────────────────────
