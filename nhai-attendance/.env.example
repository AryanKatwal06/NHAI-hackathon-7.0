# .env.example
# Copy this file to .env.development and .env.production
# and fill in the real values.
# NEVER commit .env.development or .env.production to git.

# ─── AWS SYNC CONFIGURATION ───────────────────────────────────────────────────
# Use mock sync mode for Hackathon evaluation without real AWS infrastructure
USE_MOCK_SYNC=true

# AWS API Gateway endpoint URL (Phase 7)
AWS_API_GATEWAY_URL=https://your-api-id.execute-api.ap-south-1.amazonaws.com/prod

# AWS Region (Mumbai for NHAI India deployment)
AWS_REGION=ap-south-1

# ─── WORKSITE CONFIGURATION ───────────────────────────────────────────────────
# Default worksite GPS coordinates (override in settings screen)
DEFAULT_WORKSITE_LATITUDE=28.6139
DEFAULT_WORKSITE_LONGITUDE=77.2090

# Worksite authentication radius in meters
# Logins from within this radius score HIGH location trust
WORKSITE_RADIUS_HIGH_METERS=100
# Logins from within this radius score MEDIUM location trust
WORKSITE_RADIUS_MEDIUM_METERS=500
# Logins from beyond WORKSITE_RADIUS_MEDIUM_METERS score LOW location trust

# ─── TRUST SCORE THRESHOLDS ────────────────────────────────────────────────────
# Score >= this value = Authenticated
TRUST_THRESHOLD_AUTHENTICATED=80
# Score >= this value = Flagged (below this = Rejected)
TRUST_THRESHOLD_FLAGGED=60

# ─── SIGNAL WEIGHTS (must sum to 100) ─────────────────────────────────────────
WEIGHT_FACE_MATCH=40
WEIGHT_LIVENESS=25
WEIGHT_DEVICE_TRUST=15
WEIGHT_BEHAVIORAL=10
WEIGHT_LOCATION=10

# ─── FACE RECOGNITION ─────────────────────────────────────────────────────────
# Cosine similarity threshold for face match (0.0–1.0)
# Values above this = same person, below = different person
FACE_MATCH_THRESHOLD=0.65

# ─── LIVENESS DETECTION ───────────────────────────────────────────────────────
# Number of random challenges to present per session (1 or 2)
LIVENESS_CHALLENGE_COUNT=2
# Time limit in milliseconds for each challenge
LIVENESS_CHALLENGE_TIMEOUT_MS=8000

# ─── STORAGE ──────────────────────────────────────────────────────────────────
# SQLite database filename
DB_NAME=nhai_attendance.db

# ─── APP CONFIGURATION ────────────────────────────────────────────────────────
# Application environment: 'development' | 'production'
APP_ENV=development
# Enable verbose logging (development only — MUST be false in production)
ENABLE_VERBOSE_LOGGING=true
