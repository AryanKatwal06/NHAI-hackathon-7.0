{
  "name": "nhai-hackathon-project",
  "version": "0.1.0",
  "private": true,
  "description": "NHAI Hackathon 7.0 — Offline Multi-Signal Identity Verification Framework",
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "start": "react-native start",
    "start:reset": "react-native start --reset-cache",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --forceExit",
    "test:unit": "jest __tests__/unit/ --verbose --forceExit",
    "test:integration": "jest __tests__/integration/ --verbose --forceExit",
    "lint": "eslint src/ --ext .ts,.tsx",
    "lint:fix": "eslint src/ --ext .ts,.tsx --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write 'src/**/*.{ts,tsx}' 'docs/**/*.md'",
    "audit": "bash scripts/audit_all_phases.sh",
    "benchmark": "echo 'Run benchmark from the Settings screen in the app'",
    "build:android:debug": "cd android && ./gradlew assembleDebug",
    "build:android:release": "cd android && ./gradlew assembleRelease",
    "model:download": "bash scripts/download-models.sh",
    "setup": "bash scripts/setup.sh",
    "clean:android": "cd android && ./gradlew clean && cd ..",
    "clean:ios": "cd ios && xcodebuild clean && cd ..",
    "clean:metro": "npx react-native start --reset-cache",
    "prepare": "husky",
    "postinstall": "npx patch-package"
  },
  "dependencies": {
    "@react-native-community/netinfo": "^11.0.0",
    "@react-navigation/native": "^6.1.0",
    "@react-navigation/native-stack": "^6.9.0",
    "@types/crypto-js": "^4.2.2",
    "immer": "^10.1.0",
    "react": "18.3.1",
    "react-native": "0.75.0",
    "react-native-config": "^1.5.3",
    "react-native-device-info": "^11.1.0",
    "react-native-encrypted-storage": "^4.0.3",
    "react-native-fast-tflite": "^1.3.1",
    "react-native-geolocation-service": "^5.3.1",
    "react-native-gesture-handler": "^2.19.0",
    "react-native-get-random-values": "^2.0.0",
    "react-native-keychain": "^9.1.0",
    "react-native-linear-gradient": "^2.8.3",
    "react-native-permissions": "^4.1.0",
    "react-native-quick-sqlite": "^8.1.0",
    "react-native-reanimated": "^3.16.0",
    "react-native-safe-area-context": "^4.10.0",
    "react-native-screens": "^3.34.0",
    "react-native-vector-icons": "^10.3.0",
    "react-native-vision-camera": "^4.5.0",
    "uuid": "^10.0.0",
    "zod": "^3.23.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@babel/preset-env": "^7.25.0",
    "@babel/runtime": "^7.25.0",
    "@commitlint/cli": "^19.3.0",
    "@commitlint/config-conventional": "^19.2.0",
    "@react-native-community/cli": "^20.1.3",
    "@react-native/babel-preset": "0.75.0",
    "@react-native/eslint-config": "0.75.0",
    "@react-native/metro-config": "0.75.0",
    "@react-native/typescript-config": "0.75.0",
    "@testing-library/react-native": "^12.6.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^25.9.1",
    "@types/react": "^18.3.0",
    "@types/react-native": "^0.73.0",
    "@types/react-native-vector-icons": "^6.4.18",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "babel-jest": "^29.7.0",
    "babel-plugin-module-resolver": "^5.0.0",
    "eslint": "^8.57.0",
    "husky": "^9.1.0",
    "jest": "^29.7.0",
    "lint-staged": "^15.2.0",
    "madge": "^8.0.0",
    "prettier": "^3.3.0",
    "react-test-renderer": "18.3.1",
    "typescript": "5.5.4"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=18"
  }
}
